# Frontend (Vite) public environment variables
# IMPORTANT: Only variables prefixed with VITE_ are exposed to the browser.
# Do NOT put secrets (like API keys) here. Anything in Vite .env is public.

# Preferred: full backend endpoint URL used by src/services/chatAI.js
VITE_BACKEND_CHAT_URL=http://localhost/mooai/backend/openai_chat.php

# Legacy option: backend base URL (appends /backend/openai_chat.php)
# VITE_BACKEND_BASE_URL=http://localhost/mooai
